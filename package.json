{
  "name": "intranet",
  "version": "1.0.0",
  "private": true,
  "description": "A modular private home intranet intelligence system for a single Linux server (PHP 8.2+, MySQL 8+, jQuery, Bootstrap 5 SSR-first).",
  "scripts": {
    "build:css": "tailwindcss -i ./resources/assets/css/tailwind.css -o ./public/assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./resources/assets/css/tailwind.css -o ./public/assets/css/tailwind.css --watch",
    "build:legacy-css": "tailwindcss -i ./resources/assets/css/app.css -o ./public/assets/css/app.tailwind.css --minify",
    "watch:legacy-css": "tailwindcss -i ./resources/assets/css/app.css -o ./public/assets/css/app.tailwind.css --watch",
    "build": "npm run build:css && npm run build:legacy-css",
    "dev": "npm run watch:css",
    "test": "npm run build:css",
    "audit": "npm audit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phreakin/intranet.git"
  },
  "keywords": [
    "intranet",
    "private",
    "home",
    "intelligence",
    "system",
    "php",
    "mysql",
    "jquery",
    "bootstrap",
    "tailwindcss"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/phreakin/intranet/issues"
  },
  "homepage": "https://github.com/phreakin/intranet#readme",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
