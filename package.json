{
  "name": "intranet",
  "version": "1.0.0",
  "private": true,
  "description": "A modular private home intranet intelligence system for a single Linux server (PHP 8.2+, MySQL 8+, jQuery, Bootstrap 5 SSR-first).",
  "scripts": {
    "yarn:install": "yarn install --latest",
    "yarn:update": "yarn update --latest",
    "yarn:latest": "yarn update --latest && yarn install --latest",
    "yarn:audit": "yarn audit",
    "yarn:audit:fix": "yarn audit fix",
    "yarn:audit:check": "yarn audit --json | yarn audit:check",
    "tailwindcss:watch": "tailwindcss -i ./resources/assets/css/tailwind.css -o ./public/assets/css/tailwind.css --watch",
    "build:css": "tailwindcss -i ./resources/assets/css/tailwind.css -o ./public/assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./resources/assets/css/tailwind.css -o ./public/assets/css/tailwind.css --watch",
    "build:legacy-css": "tailwindcss -i ./resources/assets/css/app.css -o ./public/assets/css/app.tailwind.css --minify",
    "watch:legacy-css": "tailwindcss -i ./resources/assets/css/app.css -o ./public/assets/css/app.tailwind.css --watch",
    "build": "npm run build:css && npm run build:legacy-css",
    "dev": "npm run watch:css",
    "test": "npm run build:css",
    "audit": "npm audit",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"./resources/assets/css/**/*.css\"",
    "format": "prettier --write \"./{*.js,*.json,*.md}\" \"./resources/**/*.{js,css,json,md}\" \"./public/assets/js/**/*.js\"",
    "format:check": "prettier --check \"./{*.js,*.json,*.md}\" \"./resources/**/*.{js,css,json,md}\" \"./public/assets/js/**/*.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phreakin/intranet.git"
  },
  "keywords": [
    "intranet",
    "private",
    "home",
    "intelligence",
    "system",
    "php",
    "mysql",
    "jquery",
    "bootstrap",
    "tailwindcss"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/phreakin/intranet/issues"
  },
  "homepage": "https://github.com/phreakin/intranet#readme",
  "dependencies": {
    "@loganmarchione/homelab-svg-assets": "*",
    "thesvg": "*",
    "@zendeskgarden/svg-icons": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-order": "^7.0.1",
    "tailwindcss": "^3.4.17"
  },
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  }
}
